---
import Layout from '../layouts/Layout.astro';
import MalaysiaMap from '../components/MalaysiaMap';
import StateMetricCards from '../components/StateMetricCards';
import StateList from '../components/StateList';
import MyWITrendChart from '../components/MyWITrendChart';
import MyWIComponentsChart from '../components/MyWIComponentsChart';
import StateComparison from '../components/StateComparison';

// New chart components for advanced analytics
import DualLineTrend from '../components/DualLineTrend';
import EmploymentStatusDonut from '../components/EmploymentStatusDonut';
import CompletionBarChart from '../components/CompletionBarChart';
import EnrolmentBubbleChart from '../components/EnrolmentBubbleChart';
import HigherEdStackedBar from '../components/HigherEdStackedBar';
import LFPRRankedBar from '../components/LFPRRankedBar';
import GDPUnemploymentScatter from '../components/GDPUnemploymentScatter';
import ProductivityHeatmap from '../components/ProductivityHeatmap';
import QuadrantScatter from '../components/QuadrantScatter';
import ClusterVisualization from '../components/ClusterVisualization';

// Graduate Tracer Study components
import GraduateFieldChart from '../components/GraduateFieldChart';
import GraduateStateRanking from '../components/GraduateStateRanking';
import PublicPrivateGapChart from '../components/PublicPrivateGapChart';
import GraduateInstitutionChart from '../components/GraduateInstitutionChart';
---

<Layout title="Malaysia Education & Employment Dashboard">
	<!-- Hero Section -->
	<section class="bg-gradient-to-br from-slate-900 via-slate-800 to-teal-900 text-white py-16 px-4 fade-in">
		<div class="max-w-7xl mx-auto text-center">
			<h1 class="text-4xl md:text-6xl font-bold mb-4">
				Education, Employment & Well-Being in Malaysia
			</h1>
			<p class="text-xl md:text-2xl text-teal-200 mb-6 font-light">
				Data Challenge 5.0 — Sustainable Well-Being
			</p>
			<p class="text-base md:text-lg max-w-3xl mx-auto text-gray-300">
				Explore how education and employment connect to well-being across Malaysian states.
				The Malaysian Well-Being Index (MyWI) reveals the full picture: from schools to jobs to quality of life.
				Click any state to see its complete well-being profile.
			</p>
		</div>
	</section>

	<!-- Map Section -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 fade-in-delay-1">
		<h2 class="text-3xl font-bold text-center mb-8 text-gray-900">
			Interactive Malaysia Map
		</h2>
		<p class="text-center text-gray-600 mb-8 max-w-2xl mx-auto">
			<strong>Currently showing:</strong> Graduate Employment Rate by State (2024)<br/>
			<span class="text-sm">Click on any state to view its complete well-being profile with MyWI index, education metrics, and economic indicators</span>
		</p>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			<!-- Map (takes 2 columns) -->
			<div class="lg:col-span-2 bg-white rounded-2xl shadow-xl p-6 md:p-10">
				<MalaysiaMap client:load />
			</div>

			<!-- State List (takes 1 column) -->
			<div class="lg:col-span-1">
				<StateList client:load />
			</div>
		</div>
	</section>

	<!-- State Metrics Section (Dynamic - appears on hover/click) -->
	<section id="state-metrics" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 hidden">
		<div class="bg-gradient-to-br from-white to-gray-50 rounded-2xl shadow-xl p-6 md:p-10 border border-gray-200">
			<StateMetricCards client:load />
		</div>

		<!-- MyWI Trend Chart -->
		<div class="mt-6">
			<MyWITrendChart client:load />
		</div>

		<!-- MyWI Components Breakdown Chart -->
		<div class="mt-6">
			<MyWIComponentsChart client:load />
		</div>
	</section>

	<!-- National Summary Cards -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 fade-in-delay-2">
		<h2 class="text-2xl font-bold text-center mb-8 text-gray-900">
			National Overview
		</h2>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
			<!-- Labour Market -->
			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-teal-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">National Unemployment Rate</h3>
				<p class="text-3xl font-bold text-gray-900">3.3%</p>
				<p class="text-xs text-gray-500 mt-1">Latest data (2023)</p>
			</div>

			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-blue-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">Labour Force Participation</h3>
				<p class="text-3xl font-bold text-gray-900">68.6%</p>
				<p class="text-xs text-gray-500 mt-1">Latest data (2023)</p>
			</div>

			<!-- Graduate Employment -->
			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-green-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">Graduate Employment Rate</h3>
				<p class="text-3xl font-bold text-gray-900">92.5%</p>
				<p class="text-xs text-gray-500 mt-1">National average (2024)</p>
			</div>

			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-purple-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">Total Graduates (2024)</h3>
				<p class="text-3xl font-bold text-gray-900">4.1M</p>
				<p class="text-xs text-gray-500 mt-1">Graduates produced</p>
			</div>
		</div>

		<!-- Additional row for economic indicators -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-6">
			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-amber-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">Mean Household Income</h3>
				<p class="text-3xl font-bold text-gray-900">RM 6,338</p>
				<p class="text-xs text-gray-500 mt-1">Latest data (2022)</p>
			</div>

			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-cyan-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">School Completion Rate</h3>
				<p class="text-3xl font-bold text-gray-900">98.5%</p>
				<p class="text-xs text-gray-500 mt-1">Average (2022)</p>
			</div>

			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-indigo-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">Best Employment Field</h3>
				<p class="text-2xl font-bold text-gray-900">Engineering</p>
				<p class="text-xs text-gray-500 mt-1">94.9% employed (2024)</p>
			</div>

			<div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-rose-500">
				<h3 class="text-sm font-medium text-gray-600 mb-2">Employment Growth</h3>
				<p class="text-3xl font-bold text-gray-900">+24%</p>
				<p class="text-xs text-gray-500 mt-1">2023 → 2024 improvement</p>
			</div>
		</div>
	</section>

	<!-- State Comparison Section -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 fade-in-delay-3">
		<StateComparison client:load />
	</section>

	<!-- NEW SECTION 1: Employment Trends Analysis -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="text-center mb-10">
			<h2 class="text-3xl font-bold text-gray-900 mb-3">
				Employment Trends Analysis
			</h2>
			<p class="text-lg text-gray-600 max-w-3xl mx-auto">
				Understanding unemployment patterns and employment composition across Malaysia (2016-2025)
			</p>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
			<DualLineTrend client:load />
			<EmploymentStatusDonut client:load />
		</div>
	</section>

	<!-- NEW SECTION 2: Education Infrastructure & Outcomes -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 bg-gray-50">
		<div class="text-center mb-10">
			<h2 class="text-3xl font-bold text-gray-900 mb-3">
				Education Infrastructure & Outcomes
			</h2>
			<p class="text-lg text-gray-600 max-w-3xl mx-auto">
				Examining education supply, completion rates, and graduate production trends
			</p>
		</div>

		<div class="space-y-6">
			<CompletionBarChart client:load />

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
				<EnrolmentBubbleChart client:load />
				<HigherEdStackedBar client:load />
			</div>
		</div>
	</section>

	<!-- NEW SECTION 3: Labour Market Dynamics -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="text-center mb-10">
			<h2 class="text-3xl font-bold text-gray-900 mb-3">
				Labour Market Dynamics
			</h2>
			<p class="text-lg text-gray-600 max-w-3xl mx-auto">
				Exploring labour force participation, economic prosperity, and sectoral productivity
			</p>
		</div>

		<div class="space-y-6">
			<LFPRRankedBar client:load />

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
				<GDPUnemploymentScatter client:load />
				<ProductivityHeatmap client:load />
			</div>
		</div>
	</section>

	<!-- NEW SECTION 4: Education-Employment Pipeline Analysis (CENTREPIECE) -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 bg-gradient-to-br from-blue-50 via-purple-50 to-teal-50">
		<div class="text-center mb-10">
			<div class="inline-block px-4 py-2 bg-purple-100 text-purple-700 rounded-full text-sm font-semibold mb-4">
				ADVANCED ANALYTICS
			</div>
			<h2 class="text-4xl font-bold text-gray-900 mb-3">
				Education-Employment Pipeline Analysis
			</h2>
			<p class="text-lg text-gray-600 max-w-3xl mx-auto">
				Strategic insights from composite indices and K-means clustering analysis
			</p>
		</div>

		<div class="space-y-8">
			<!-- Quadrant Scatter - The most important visualization -->
			<div class="bg-white rounded-lg shadow-lg p-2 border-4 border-purple-200">
				<QuadrantScatter client:load />
			</div>

			<!-- Cluster Visualization -->
			<div class="bg-white rounded-lg shadow-lg p-2">
				<ClusterVisualization client:load />
			</div>
		</div>
	</section>

	<!-- SECTION 8: Graduate Tracer Study Deep Dive (2020-2024) -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 bg-gradient-to-br from-slate-900 via-slate-800 to-teal-900">
		<div class="text-center mb-10">
			<div class="inline-block px-4 py-2 bg-teal-100 text-teal-700 rounded-full text-sm font-semibold mb-4">
				📊 GRADUATE OUTCOMES
			</div>
			<h2 class="text-4xl font-bold text-white mb-3">
				Graduate Tracer Study Deep Dive (2020–2024)
			</h2>
			<p class="text-lg text-teal-200 max-w-3xl mx-auto">
				Comprehensive analysis of graduate employment outcomes across fields, states, and institution types
			</p>
			<p class="text-sm text-gray-300 mt-3">
				⚠ Note: 2024 uses different methodology (binary GE rate) vs 2020-2023 (5-category classification)
			</p>
		</div>

		<div class="space-y-8">
			<!-- Row 1: Field of Study & State Ranking -->
			<div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
				<div class="bg-white rounded-lg shadow-lg">
					<GraduateFieldChart client:load />
				</div>
				<div class="bg-white rounded-lg shadow-lg">
					<GraduateStateRanking client:load />
				</div>
			</div>

			<!-- Row 2: Public-Private Gap (Full Width - KEY INSIGHT) -->
			<div class="bg-white rounded-lg shadow-lg">
				<PublicPrivateGapChart client:load />
			</div>

			<!-- Row 3: Institution Type Comparison -->
			<div class="bg-white rounded-lg shadow-lg">
				<GraduateInstitutionChart client:load />
			</div>

			<!-- Summary Insights -->
			<div class="bg-white rounded-xl p-6 md:p-8 shadow-lg">
				<h3 class="text-2xl font-bold text-gray-900 mb-4">
					🎯 Key Graduate Employment Findings
				</h3>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
						<p class="text-sm font-bold text-red-900 mb-2">Geographic Disparities</p>
						<p class="text-sm text-red-800">
							Sabah (11.0%), Kelantan (10.9%), and Sarawak (9.8%) show persistently high graduate unemployment,
							while Putrajaya (4.7%) and Labuan (6.0%) outperform the national average of 7.5% (2024).
						</p>
					</div>
					<div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
						<p class="text-sm font-bold text-green-900 mb-2">Field Performance</p>
						<p class="text-sm text-green-800">
							Engineering graduates excel with only 5.1% unemployment (2024), while Education (10.2%),
							Services (10.1%), and Agriculture (10.0%) face structural challenges.
						</p>
					</div>
					<div class="bg-purple-50 border-l-4 border-purple-500 p-4 rounded">
						<p class="text-sm font-bold text-purple-900 mb-2">Public vs Private Gap</p>
						<p class="text-sm text-purple-800">
							Private HEI graduates are 2.5x more likely to be unemployed than public university graduates,
							with a persistent gap of 7-10 percentage points across all years (2020-2024).
						</p>
					</div>
					<div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
						<p class="text-sm font-bold text-blue-900 mb-2">Institution Type Impact</p>
						<p class="text-sm text-blue-800">
							Polytechnics (1.2%) and Community Colleges (1.2%) show exceptional employment outcomes,
							suggesting strong industry-aligned training programs compared to degree-granting institutions.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- State Detail Section (Hidden initially, shown on state click) -->
	<section id="state-detail" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 hidden">
		<div class="bg-white rounded-2xl shadow-xl p-6 md:p-10">
			<h2 class="text-3xl font-bold mb-8 text-gray-900" id="state-detail-title">
				State Details
			</h2>
			<!-- State detail charts will be added here -->
			<p class="text-gray-600 text-center py-12">
				Click on a state in the map above to view detailed employment, education, and economic trends.
			</p>
		</div>
	</section>

	<!-- About / Methodology Section -->
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 fade-in-delay-3">
		<div class="bg-gradient-to-r from-teal-50 to-blue-50 rounded-2xl p-8 md:p-12">
			<h2 class="text-3xl font-bold mb-6 text-gray-900">About This Dashboard</h2>
			<div class="prose prose-lg max-w-none">
				<p class="text-gray-700 mb-4">
					This interactive dashboard visualizes Malaysia's education and employment outcomes using official data from the
					<strong>Department of Statistics Malaysia (DOSM)</strong>. The dashboard is designed to support data-driven
					decision-making around sustainable well-being initiatives.
				</p>

				<h3 class="text-xl font-semibold mt-6 mb-3 text-gray-900">Data Sources</h3>
				<ul class="list-disc pl-6 text-gray-700 space-y-2">
					<li><strong>Malaysian Well-Being Index (MyWI) 2010-2024</strong> — State-level well-being index with 3 sub-composites (Economic, Social, Environmental) and 16 components. Base year 2010 = 100.</li>
					<li><strong>Labour Force Survey (LFS)</strong> — Annual, quarterly, and monthly employment statistics by state and demographic</li>
					<li><strong>Graduate Tracer Study (2023-2024)</strong> — Graduate employment outcomes by state and field from Ministry of Higher Education</li>
					<li><strong>Graduates Statistics (2020-2024)</strong> — Graduate production trends by state with gender breakdown</li>
					<li><strong>GDP by State</strong> — Economic output by sector at constant 2015 prices</li>
					<li><strong>Household Income & Inequality</strong> — Mean, median income, and Gini coefficients by state</li>
					<li><strong>Education Statistics</strong> — School completion, enrolment, teachers, and lecturers data by state and district</li>
				</ul>

				<h3 class="text-xl font-semibold mt-6 mb-3 text-gray-900">Key Metrics Explained</h3>
				<ul class="list-disc pl-6 text-gray-700 space-y-2">
					<li><strong>MyWI (Malaysian Well-Being Index)</strong> — Composite index measuring quality of life across economic, social, and environmental dimensions. Base year 2010 = 100. Values above 100 indicate improvement.</li>
					<li><strong>MyWI Sub-Composites</strong> — Economic (transportation, communication, income, working life), Social (education, housing, entertainment, safety, participation, governance, culture, health, family), Environmental (air, water, biodiversity)</li>
					<li><strong>MyWI Education Component</strong> — State's performance in education indicators within the well-being index</li>
					<li><strong>MyWI Working Life Component</strong> — Quality of employment conditions and opportunities</li>
					<li><strong>Graduate Employment Rate</strong> — Percentage of recent graduates who are employed</li>
					<li><strong>Employment Absorption Rate</strong> — Percentage of graduates produced who find employment (indicates market capacity)</li>
					<li><strong>Unemployment Rate</strong> — Percentage of labour force actively seeking work</li>
					<li><strong>Labour Force Participation Rate</strong> — Percentage of working-age population in the labour force</li>
					<li><strong>Gini Coefficient</strong> — Income inequality measure (0 = perfect equality, 1 = perfect inequality)</li>
					<li><strong>School Completion Rate</strong> — Percentage of students completing each education level</li>
				</ul>

				<p class="text-sm text-gray-600 mt-8">
					<strong>Data Integration:</strong> This dashboard integrates the Malaysian Well-Being Index (MyWI) 2010-2024 with
					structured CSV data from OpenDOSM and extracted PDF data from Ministry of Higher Education (Graduate Tracer Studies 2023-2024,
					Graduates Statistics 2020-2024). The integration provides a complete view of the education → employment → well-being
					connection across all Malaysian states.
				</p>
				<p class="text-xs text-gray-500 mt-4">
					<strong>Note on Wilayah Persekutuan:</strong> MyWI data combines Kuala Lumpur, Putrajaya, and Labuan into one
					"Wilayah Persekutuan" entity. The same MyWI values are applied to all three federal territories on this dashboard.
				</p>
			</div>
		</div>
	</section>

	<!-- Copyright Footer -->
	<footer class="bg-slate-900 border-t border-slate-800">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
			<div class="text-center">
				<p class="text-slate-400 text-sm mb-2">
					© 2026 <span class="font-semibold text-teal-400">Group TBD</span> — Created for <span class="font-semibold text-teal-400">Data Challenge 5.0</span>
				</p>
				<p class="text-slate-500 text-xs">
					Built with ❤️ using Astro, React, and Recharts | Data sources: DOSM, MOHE, EPU
				</p>
			</div>
		</div>
	</footer>
</Layout>

<script>
	// Handle state click events
	document.addEventListener('DOMContentLoaded', () => {
		console.log('Dashboard loaded');

		// Listen for state click events from React components
		window.addEventListener('stateClick', (event) => {
			const { stateName, stateData } = event.detail;
			const stateMetricsSection = document.getElementById('state-metrics');

			if (stateName && stateData) {
				// Show the section with data
				stateMetricsSection?.classList.remove('hidden');
				stateMetricsSection?.classList.add('animate-fadeIn');

				// Update cards with state data
				window.dispatchEvent(new CustomEvent('updateStateMetrics', {
					detail: { stateName, stateData }
				}));

				// Update MyWI trend chart with state name
				window.dispatchEvent(new CustomEvent('updateMyWIChart', {
					detail: { stateName }
				}));

				// Smooth scroll to metrics section
				setTimeout(() => {
					stateMetricsSection?.scrollIntoView({
						behavior: 'smooth',
						block: 'center'
					});
				}, 100);
			}
		});
	});
</script>
